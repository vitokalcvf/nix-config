#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
runtime_dir="${NOCTALIA_CONFIG_DIR:-$HOME/.config/noctalia}"
target_dir="$repo_root/modules/dotfiles/noctalia"

settings_file="$runtime_dir/settings.json"
colors_file="$runtime_dir/colors.json"
plugins_file="$runtime_dir/plugins.json"

mkdir -p "$target_dir"

if [[ -f "$settings_file" ]]; then
  nix eval --impure --json --expr \
    "{ settings = builtins.fromJSON (builtins.readFile \"$settings_file\"); }" \
    > "$target_dir/noctalia.json"
else
  echo "Aviso: $settings_file nao existe; mantendo $target_dir/noctalia.json como esta." >&2
fi

if [[ -f "$colors_file" ]]; then
  cp "$colors_file" "$target_dir/colors.json"
fi

if [[ -f "$plugins_file" ]]; then
  cp "$plugins_file" "$target_dir/plugins.json"
fi

if [[ -d "$runtime_dir/colorschemes" ]]; then
  rm -rf "$target_dir/colorschemes"
  cp -R "$runtime_dir/colorschemes" "$target_dir/colorschemes"
fi

if [[ -d "$runtime_dir/plugins" ]]; then
  mkdir -p "$target_dir/plugins"
  find "$runtime_dir/plugins" -mindepth 2 -maxdepth 2 -name settings.json -print | while read -r plugin_settings; do
    plugin_name="$(basename -- "$(dirname -- "$plugin_settings")")"
    mkdir -p "$target_dir/plugins/$plugin_name"
    cp "$plugin_settings" "$target_dir/plugins/$plugin_name/settings.json"
  done
fi

echo "Noctalia sincronizado para $target_dir"
